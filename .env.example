# PkVision Environment Configuration

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite:///./pkvision.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/pkvision

# API
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# YOLO model (auto-downloads if not found)
YOLO_MODEL_PATH=yolo11n-pose.pt

# ST-GCN trained model path
STGCN_MODEL_PATH=data/models/stgcn_best.pt

# Trick catalog language
DEFAULT_LANGUAGE=en

# Celery (future async processing)
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Detection confidence threshold (0.0 - 1.0)
CONFIDENCE_THRESHOLD=0.5
