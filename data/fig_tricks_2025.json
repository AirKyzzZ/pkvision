    "source": "FIG Parkour Code of Points 2025-2028 — Table of Tricks 2025",
    "url": "https://www.gymnastics.sport/publicdir/rules/files/en_1.1.1%20-%20PK%20Code%20of%20Points%202025-2028%20-%20Table%20of%20tricks%202025.pdf",
    "date": "April 2025",
    "author": "Parkour Technical Committee",
    "notes": "Base difficulty values in most basic form. Judges upscale via Scaling (Placement, Form, Entry, Exit). Slanted axis moves get -0.5. Failed tricks (-4.00 or -6.00 deduction) don't count in difficulty."
  },
  "scoring": {
    "e_score": {
      "safety": {"max": 9, "deductions": [-0.10, -0.30, -0.50, -1.00, -2.00, -3.00, -4.00, -6.00]},
      "landing_quality": {"max": 3, "ranges": {"poor": [0, 0.5], "medium": [0.6, 1.5], "good": [1.6, 3.0]}},
      "flow": {"max": 6, "deductions": [-0.10, -0.30, -0.50, {"range": [-1.00, -5.00], "reason": "full_stop"}]},
      "flow_quality": {"max": 1, "ranges": {"poor": [0, 0.2], "medium": [0.3, 0.7], "good": [0.8, 1.0]}}
    },
    "d_score": {
      "scaling_situations": ["placement", "form", "entry", "exit"],
      "slanted_axis_penalty": -0.5,
      "failed_trick_rule": "Tricks with -4.00 or -6.00 deduction do not count in difficulty",
      "repeat_rule": "Repeated tricks will not be considered, even if they differ in form, entry, placement, or exit"
    }
  },
